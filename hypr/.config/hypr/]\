################
### MONITORS ###
################

# See https://wiki.hyprland.org/Configuring/Monitors/
#monitor=,preferred,auto,auto # For default config
#monitor = DP-1, 3440x1440@144, 1080x560, 1, bitdepth, 10, cm, hdr # For to enable HDR10
monitor = DP-1, 3440x1440@160, 0x560, 1
monitor = HDMI-A-1, 2560x1080@75, 3440x0, 1, transform, 3

# Set second monitor permanently to another workspace to not change
workspace = 1, monitor:DP-1, default:true
workspace = 2, monitor:DP-1
workspace = 3, monitor:DP-1
workspace = 4, monitor:DP-1
workspace = 5, monitor:DP-1
workspace = 6, monitor:DP-1
workspace = 7, monitor:DP-1
workspace = 8, monitor:DP-1
workspace = 9, monitor:DP-1
workspace = 10, monitor:HDMI-A-1, persistent:true, default:true

