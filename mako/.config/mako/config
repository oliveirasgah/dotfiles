# Global
max-visible=5
sort=-time
layer=overlay
anchor=top-center
output=DP-1

# Dimensions
width=420
height=130
margin=12
padding=12
border-size=2
border-radius=12

# Timing
default-timeout=5000
ignore-timeout=0

# Colors — Catppuccin Macchiato
background-color=#24273add
text-color=#cad3f5ff
border-color=#c6a0f6ff
progress-color=over #363a4fff

# Typography
font=sans-serif 11

# Icons
icons=1
max-icon-size=48

# Urgency: low
[urgency=low]
border-color=#8aadf4ff
default-timeout=3000

# Urgency: normal
[urgency=normal]
border-color=#c6a0f6ff
default-timeout=5000

# Urgency: high
[urgency=high]
border-color=#ed8796ff
text-color=#ed8796ff
default-timeout=0
