{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "console_title_template": "{{ .Folder }} » {{ .Shell }}",
  "palette": {
    "fg": "#f8f8f2",
    "bg": "#282a36",
    "purple": "#5050aa",
    "orange": "#ffb86c",
    "red": "#ff5555",
    "green": "#50fa7b",
    "lilac": "#906cff",
    "lilac-fg": "#100e23",
    "pink": "#ff79c6",
    "blue": "#6272a4"
  },
  "transient_prompt": {
    "template": "  ❯❯ {{ .AbsolutePWD }} : ",
    "foreground": "p:fg",
    "background": "transparent",
    "newline": true
  },
  "upgrade": {
    "auto": false,
    "interval": "168h",
    "notice": true
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "template": "\n╭─",
          "foreground": "p:fg",
          "type": "text",
          "style": "plain"
        },
        {
          "leading_diamond": "",
          "template": "{{ .UserName }}",
          "foreground": "p:fg",
          "background": "p:bg",
          "type": "session",
          "style": "diamond"
        },
        {
          "template": "󱐋",
          "foreground": "p:red",
          "powerline_symbol": "",
          "background": "p:bg",
          "type": "root",
          "style": "powerline"
        },
        {
          "template": "{{ .Icon }}  ",
          "foreground": "p:fg",
          "powerline_symbol": "",
          "background": "p:bg",
          "type": "os",
          "style": "powerline"
        },
        {
          "properties": {
            "style": "full"
          },
          "template": " 󰉖 {{ path .Path .Location }}",
          "powerline_symbol": "",
          "foreground": "p:fg",
          "background": "p:purple",
          "type": "path",
          "style": "powerline"
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "",
          "foreground": "p:lilac-fg",
          "background": "p:lilac",
          "properties": {
            "fetch_virtual_env": true,
            "display_mode": "environment",
            "home_enabled": true
          },
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }} "
        },
        {
          "properties": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "full_branch_path": true
          },
          "template": "  ({{ url .UpstreamIcon .UpstreamURL }} {{ url .HEAD .UpstreamURL }}){{ if gt .Ahead 0 }}<p:green> +{{ .Ahead }}</>{{ end }}{{ if gt .Behind 0 }}<p:red> -{{ .Behind }}</>{{ end }}{{ if .Working.Changed }}<p:fg>  {{ .Working.String }}</>{{ end }}{{ if .Staging.Changed }}<p:fg>  {{ .Staging.String }}</>{{ end }} ",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:orange",
          "type": "git",
          "style": "powerline"
        },
        {
          "template": " {{ .Full }}",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:green",
          "type": "node",
          "style": "powerline"
        },
        {
          "properties": {
            "display_mode": "files",
            "extensions": ["package-lock.json"]
          },
          "template": " {{ .Full }}",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:red",
          "type": "npm",
          "style": "powerline"
        },
        {
          "properties": {
            "display_mode": "files",
            "extensions": ["pnpm-lock.yaml"]
          },
          "template": "󰋁 {{ .Full }}",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:orange",
          "type": "pnpm",
          "style": "powerline"
        },
        {
          "properties": {
            "display_mode": "files"
          },
          "template": " {{ .Full }}",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:green",
          "type": "python",
          "style": "powerline"
        },
        {
          "template": " {{ .Full }}",
          "powerline_symbol": "",
          "foreground": "p:bg",
          "background": "p:pink",
          "type": "java",
          "style": "powerline"
        },
        {
          "template": " {{ .Full }}",
          "powerline_symbol": "",
          "foreground": "p:fg",
          "background": "p:blue",
          "type": "php",
          "style": "powerline"
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "p:orange",
          "properties": {
            "threshold": 500,
            "style": "austin"
          },
          "template": "  {{ .FormattedMs }} "
        },
        {
          "type": "status",
          "style": "plain",
          "foreground": "p:red",
          "properties": {
            "always_enabled": false
          },
          "template": "  {{ .Code }} "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "always_enabled": true
          },
          "template": "╰─ ❯❯",
          "foreground": "p:fg",
          "type": "text",
          "style": "diamond"
        }
      ],
      "newline": true
    }
  ]
}
